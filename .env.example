APP_NAME=SIKARA
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://sikara.naufalmohy.me

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=sqlite
# Jika menggunakan MySQL di production:
# DB_CONNECTION=mysql
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=nama_database
# DB_USERNAME=db_user
# DB_PASSWORD=db_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local

# PENTING: Gunakan "sync" agar email dikirim langsung tanpa queue worker
QUEUE_CONNECTION=sync

CACHE_STORE=database

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# =============================================
# KONFIGURASI EMAIL (WAJIB DIISI DI PRODUCTION)
# =============================================
# Gunakan Gmail dengan App Password (bukan password biasa)
# Cara buat App Password: https://myaccount.google.com/apppasswords
# (Syarat: Aktifkan 2-Step Verification di akun Gmail terlebih dahulu)
MAIL_MAILER=smtp
MAIL_SCHEME=tls
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=email_gmail_kamu@gmail.com
MAIL_PASSWORD=app_password_16_karakter_disini
MAIL_FROM_ADDRESS=email_gmail_kamu@gmail.com
MAIL_FROM_NAME="SIKARA"
# =============================================

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="SIKARA"
